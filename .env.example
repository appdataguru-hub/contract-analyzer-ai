# === GigaChat (required) ===
# Get credentials from https://developers.sber.ru/gigachat
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=true

# === Qdrant Vector Database ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# === Embeddings ===
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# === RAG Parameters ===
COLLECTION_NAME=contracts
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# === API Security ===
API_KEY=
MAX_FILE_SIZE_MB=20

# === CORS ===
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

# === Logging ===
LOG_LEVEL=INFO

# === Evaluation ===
# Backend: "auto" (default), "gigachat", or "deepeval"
EVAL_BACKEND=auto
# DeepEval requires OPENAI_API_KEY (optional, only if using deepeval backend)
# OPENAI_API_KEY=your_openai_key_here
